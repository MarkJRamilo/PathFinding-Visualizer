@code {
    
    //Setup for grids and individual nodes
    PathFindingAlgorithms? pathfindingAlgorithm;
    MazeGenerationAlgorithms? generateMaze;
    Node? tempNodeForMouseEventInterlop = new Node();
    DotNetObjectReference<Home>? DotNetMethodReferenceForJS;
    public Node[,]? grid;
    int nodeSize;
    int numberGridRows = 61;
    int numberofGridColumns = 25; 
    int alotedSpaceForHeader;
    int gridWidthRemainder; // remainder from (width space/ nodsize)
    int endnodeCount; // limited to 3
    double  transitionDelay = 0.5;
    int pathfindingAlgorithmSpeed = 1;
    string pathfindingSpeedMode = "Normal";


    //bools for search algorithms interactions
    bool razorIntializeDone = false;
    bool isAlgorithmalreadyInProgress = false;
    bool isAlgorithmalreadyPaused = false;
    bool pathfindingAlgoFinished = true; //default to true to avoid running algo when moving special nodes

    //For buttons
    bool showMazeSelection = false;
    bool showSearchAlgorithmSelection = false;
    string currentlyActiveSearchAlgorithm = "Breadth-First"; //watching out for Bidirectional (remove extra endnodes until 1 is left)

    //FOR READABLITY ONLY (Buttons looks confusing and hardcoded without this)
    //Button State Constants
    const string Disabled = "header-button-disabled";
    const string Enabled = "header-button-enabled";
    const string Active = "header-button-active";
    const string ActiveClickable = "header-button-active-clickable"; //for paintWallButtonState and EndnodeAndWallEraserButtonState

    public enum ButtonType{
        GenerateMaze,
        RunSearchAlgorithm,
        PaintWall,
        PauseSearch,
        ResetSearch,
        ClearWalls,
        AddEndnode,
        EndnodeAndWallEraser
    }

    //ButtonState used to define CSS class (Functional)
    string generateMazeButtonState = Enabled;
    string pathFindingAlgorithmsButtonState = Enabled;
    string runSearchAlgorithmButtonState = Enabled;
    string paintWallButtonState = Enabled;
    string cleartWallButtonState = Enabled;
    string pauseButtonState = Disabled;
    string resetButtonState = Disabled;
    string addEndnodeButtonState = Enabled;
    string EndnodeAndWallEraserButtonState = Enabled;
    string speedButtonState = Enabled;

    //For Manual Interactions
    bool manualEnabled = true;
    int manualCurrentPageNumber = 0;
  



    protected override void OnInitialized()
    {
        //For JS Interlop using instance method
        DotNetMethodReferenceForJS = DotNetObjectReference.Create(this);

        grid = new Node[numberGridRows, numberofGridColumns];
    }

    //INVOKE JAVASCRIPT for mouse event Listeners
    IJSObjectReference? module;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./Pages/Home.razor.js");
            Console.WriteLine("Entered First Render");
            await module.InvokeVoidAsync("testIJSConnection", DotNetMethodReferenceForJS);

            //document height and width to assing the correct size and position to nodes
            nodeSize = await module.InvokeAsync<int>("passViewPortWidthSize") / numberGridRows; //limit column 
            gridWidthRemainder = await module.InvokeAsync<int>("passViewPortWidthSize") % nodeSize; //IF USING screen.innerwidth (unse top if using document DOM size that is affected by minimize when ran)

           // if(nodeSize % 2 != 0) nodeSize += 1; //bring back remainder lost from / numberGridRows if numberGridRows is odd

            //alotedSpaceForHeader = await module.InvokeAsync<int>("passViewPortHeightSize") - (nodeSize * numberofGridColumns); //alot space for header
            alotedSpaceForHeader = nodeSize * 5; //IF USING screen.innerheight (unse top if using document DOM size that is affected by minimize when ran)

            //pass needed callback and sizes required to map nodes using index
            
            

            //Generate Grid
            for (int r = 0; r < grid?.GetLength(0); r++)
            {

                for (int c = 0; c < grid.GetLength(1); c++)
                {                                //aloted space to make width in middle
                    grid[r, c] = new Node(r, c ,((gridWidthRemainder/2)+(r * nodeSize)) ,alotedSpaceForHeader +  (c * nodeSize) ); //(Node Row Positon, Node Column Positon) (using /2 if using screen.innnerwidth)
                }

            }

            pathfindingAlgorithm = new PathFindingAlgorithms(updateDOMState, algorithmCompletesWithoutUserInterupting, grid!);
            generateMaze = new MazeGenerationAlgorithms(updateDOMState, grid!);

            //set initial starting and end point
            grid?[20, 10].setAsNewInitialStartPoint();
            addEndnode();
            //grid[30, 5].setAsNewEndPoint();
            //grid[35, 5].setAsNewEndPoint();

            razorIntializeDone = true; //allow home.razor to render grid
            await InvokeAsync(StateHasChanged);

        }// To follow Dispose Asynch for JAVA Module (if done using)

    }


    //For Mouseclick 2
    [JSInvokable]
    public async Task<string> MouseDownOnNodeBehavior(int xMousePosition, int yMousePosition)
    {
        Node? node = getNodeWithCoordinates(xMousePosition, yMousePosition);//get node Clciks
        string nodeMouseMoveChangeType = "empty";// [NodeIsStartNode, NodeIsEndNode] (ei. bool[true, false] => startnode / bool[false, true] =>
        tempNodeForMouseEventInterlop = node; //Global Variable to carry over to MouseMove Method (will swap Node type)
        if(node == null) return nodeMouseMoveChangeType; //return if their is no valid node on pointers

        if(paintWallButtonState == ActiveClickable
        && node.InitialStartPoint != true //Drag instead of pain when mousedown on starting point
        && node.EndPoint != true) //Drag instead of pain when mousedown on endnode
        {
            node.setAsWall();
            StateHasChanged();
            return "PaintWall"; //trigger one Paintwall and return
        }
        else if(EndnodeAndWallEraserButtonState == ActiveClickable
            && (endnodeCount != 1 || !node.EndPoint) //Drag instead of erase when mousedown on last endnode
            && node.InitialStartPoint != true) //Drag instead of erase when mousedown on starting point
        {
            if(node.EndPoint) 
            {
                endnodeCount--;
                node.resetToNormalNodeForEraser();
                addEndnodeButtonState = Enabled; //allow adding endnode (disabled at max 3)
                StateHasChanged();
            }
            else if(node.isWall)
            {
                node.removeWall();
                StateHasChanged();
            }
            
           return "EndnodeAndWallEraser";  //trigger one erase and return
        } 
        //Proceed to transferSpecialNode if not returned

        //Check if node clicked is InitialPoint or End Point
        if (node.InitialStartPoint == true) 
        {
            //Remove active status of buttons
            if(paintWallButtonState == ActiveClickable) paintWallButtonState = Enabled;
            if(EndnodeAndWallEraserButtonState == ActiveClickable) EndnodeAndWallEraserButtonState = Enabled;

            Console.WriteLine("Clicked Node is special");
            nodeMouseMoveChangeType = "TransferSpecialNode";
            await InvokeAsync(StateHasChanged);
            return nodeMouseMoveChangeType;

        }
        else if (node.EndPoint == true)
        {
            //Remove active status of buttons
            if(paintWallButtonState == ActiveClickable) paintWallButtonState = Enabled;
            if(EndnodeAndWallEraserButtonState == ActiveClickable) EndnodeAndWallEraserButtonState = Enabled;

            Console.WriteLine("Clicked Node is special");
            nodeMouseMoveChangeType = "TransferSpecialNode";
            await InvokeAsync(StateHasChanged);
            return nodeMouseMoveChangeType;
        }
        else
        {
            Console.WriteLine("Clicked Node is NOT special");
            return nodeMouseMoveChangeType;
        }
    }

    [JSInvokable]
    public async void MouseMoveOnNodes(int xMousePosition, int yMousePosition, string nodeChangeType)
    {   
        Node? pointingAtThisNode = getNodeWithCoordinates(xMousePosition, yMousePosition); //returns null if out of bounds
        if(pointingAtThisNode == null) return;

        if(nodeChangeType == "PaintWall")
        {
            pointingAtThisNode.setAsWall();
            //cleartWallButtonState = Enabled;
            StateHasChanged();
            return;
        }else if(nodeChangeType == "EndnodeAndWallEraser")
        {
            if(pointingAtThisNode.EndPoint && endnodeCount != 1) 
            {
                endnodeCount--;
                pointingAtThisNode.resetToNormalNodeForEraser();

                addEndnodeButtonState = Enabled; //allow adding endnode (disabled at max 3)
                StateHasChanged();
            }
            else if(pointingAtThisNode.isWall)
            {
                pointingAtThisNode.removeWall();
                StateHasChanged();
            }
            return;
        }

        if (nodeChangeType == "TransferSpecialNode"
        && tempNodeForMouseEventInterlop != getNodeWithCoordinates(xMousePosition, yMousePosition)
        && pointingAtThisNode.InitialStartPoint != true //Avoid overiding types that are already in the node
        && pointingAtThisNode.EndPoint != true)
        {

            //swap node type (if MouseDown on Special Node) to another node
            if (tempNodeForMouseEventInterlop?.InitialStartPoint == true)
            {
                tempNodeForMouseEventInterlop.swapNodeFromUserMouseMove(false, true);
                tempNodeForMouseEventInterlop = pointingAtThisNode; //Assign new in case user still holds to other nodes

                pointingAtThisNode.swapNodeFromUserMouseMove(true, true);
                StateHasChanged();

            }
            else if (tempNodeForMouseEventInterlop?.EndPoint == true)
            {
                tempNodeForMouseEventInterlop.swapNodeFromUserMouseMove(false, false);
                tempNodeForMouseEventInterlop = pointingAtThisNode;
                pointingAtThisNode.swapNodeFromUserMouseMove(true, false);
    
                StateHasChanged();
            }
            else
            {
                Console.WriteLine("NODE Start/End type ERROR!");
            }
            await runSearchAlgorithm(false);
        }
        else if(nodeChangeType == "ToWall")
        {

        }

    } 
}

