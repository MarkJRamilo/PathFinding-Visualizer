@code {

    public async Task runSearchAlgorithm(bool isUsingButton)
    {
        if(runSearchAlgorithmButtonState == Disabled)return;

        if(isUsingButton //"run" method used by button click (with ONLY AFTER PATHFIND IS DONE and BEST PATH SHOWN WITHOUT PAUSE) 
        && pathfindingAlgoFinished //different behavior when algo finished and best path is shown
        && !isAlgorithmalreadyPaused)//ignore if paused
        { 
            transitionDelay = 0; //remove transition for reset
            await resetSearchAlgorithm();
            updateButtonStatesWhenClicked(ButtonType.RunSearchAlgorithm);
            isAlgorithmalreadyPaused = false; //enable pause again
            isAlgorithmalreadyInProgress = true; //allow algo to run if moving special nodes
            pathfindingAlgoFinished = false; //disable showing best path with 0 delay
            if(pathfindingAlgorithmSpeed != 3) transitionDelay = 0.5; //Speed mode instant has 0 transition
            pathfindingAlgorithm!.removePause();
            await pathfindingAlgorithm!.runSearch(currentlyActiveSearchAlgorithm); //returns false if done
            //updateButtonStatesWhenTaskDone(ButtonType.RunSearchAlgorithm);
        }
        else if(isUsingButton //"run" method used by button click (for paused pathfind and grid is clear of visited nodes)
        && (!isAlgorithmalreadyInProgress || isAlgorithmalreadyPaused)) //Algo not yet "ran" OR is algo paused (play again and skip if paused)
        {
            updateButtonStatesWhenClicked(ButtonType.RunSearchAlgorithm);
            isAlgorithmalreadyPaused = false; //enable pause again
            isAlgorithmalreadyInProgress = true; //allow algo to run if moving special nodes
            pathfindingAlgoFinished = false; //disable showing best path with 0 delay
            if(pathfindingAlgorithmSpeed != 3) transitionDelay = 0.5; //Speed mode instant has 0 transition
            else{transitionDelay = 0;}
            pathfindingAlgorithm!.removePause();
            await pathfindingAlgorithm!.runSearch(currentlyActiveSearchAlgorithm); //returns false if done
            //updateButtonStatesWhenTaskDone(ButtonType.RunSearchAlgorithm);


        }
        //"run" method used by "MoveSpecialElement" method when moving special nodes
        else if(!isUsingButton && isAlgorithmalreadyInProgress) //avoid starting algo when user moved mouse and if user did not clicked start
        {

            //dont pause if algorithm completed, allowing it always show best path
            if(!pathfindingAlgoFinished){
                await pauseSearchAlgorithm(); //pause algo process when user moved special node mid process
            }

            transitionDelay = 0;
            await pathfindingAlgorithm!.runSearch(currentlyActiveSearchAlgorithm);

        }

           updateButtonStatesWhenTaskDone(ButtonType.RunSearchAlgorithm);

    }
    public async Task pauseSearchAlgorithm()
    {
        if(pauseButtonState != Enabled)return;

        updateButtonStatesWhenClicked(ButtonType.PauseSearch);
        if(!isAlgorithmalreadyPaused) //Allows pausing when user moved special node mid algo process to work properly (also avoid redundant pause with button)
        {

            pathfindingAlgorithm!.pauseAlgorithmAndSetDelayZero();
            isAlgorithmalreadyPaused = true;
            transitionDelay = 0; //remove lag
            //isAlgorithmalreadyInProgress = false; will completely stop algo when user moved special node mid process
        }



    }
    public async Task resetSearchAlgorithm()
    {    
        transitionDelay = 0;
        if(resetButtonState != Enabled)return;
        pathfindingAlgorithm!.pauseAlgorithmAndSetDelayZero();
        
        //NOTE: causing lag in change color (FIXED but updating DOM by sets by distance instead of individualy)
        await pathfindingAlgorithm!.resetPathFindAlgorithm(true);

        //Prevent algorithm from running moving special elements
        isAlgorithmalreadyInProgress = false;

        await Task.Delay(50); //delay for transitionDelay = 0 to apply
        if(pathfindingAlgorithmSpeed != 3) transitionDelay = 0.5;
        updateButtonStatesWhenClicked(ButtonType.ResetSearch);
    }
    void algorithmCompletesWithoutUserInterupting(){ //called when algorithm completed and showed best path

        //when user move special nodes it usually pauses if process incomplete
        //This stop pausing if the algo process completes -> allowing it to show best path when moving speical nodes
        pathfindingAlgoFinished = true; //enable showing best path with 0 delay when moving special nodes
        updateButtonStatesWhenTaskDone(ButtonType.RunSearchAlgorithm);

    }

    public async Task runMazeGenerationAlgorithms(string algorithmToRun)
    {
        if(generateMazeButtonState != Enabled)return;
         
        await resetSearchAlgorithm();
        updateButtonStatesWhenClicked(ButtonType.GenerateMaze);
        StateHasChanged();
        transitionDelay = 0.5; //redundant but fixes transition issues (leaving resetSearchAlgorithm() at 0 transition delay)
        await generateMaze!.run(algorithmToRun);
        showMazeSelection = false;
        updateButtonStatesWhenTaskDone(ButtonType.GenerateMaze);

        if(pathfindingAlgorithmSpeed == 3) transitionDelay = 0; //Bring back to 0 if speed is intant
    }

    public async Task modifyActiveSearchAlgo(string algorithmName){

        currentlyActiveSearchAlgorithm = algorithmName;
        showSearchAlgorithmSelection = false;

        if(generateMazeButtonState != Active){ //dont reset if maze is generating (already resets pathfinding algorithm search in grid)
        await resetSearchAlgorithm();
        }

        if(currentlyActiveSearchAlgorithm == "Bidirectional") //Only limited to 1 endnode
        {
            addEndnodeButtonState = Disabled; //Also updated hardcoded button state interactions in switch

            if(endnodeCount != 1) //if endnode is more than 1)
            {
                pathfindingAlgorithm!.removeExcessEndnodesForBidirectional(); // will leave 1 endnode
                endnodeCount = 1; 
            }
        }else if(endnodeCount < 3) addEndnodeButtonState = Enabled; //Reanable in case coming from "Bidirectional" Search
    }

    public void showButtonSelection(string selectionOf){

        if(selectionOf == "Maze"){
            if(generateMazeButtonState != Enabled) return; //(disabled when generating maze in progress)
            showMazeSelection = true; //toggle 

        }else if(selectionOf == "SearchAlgorithm"){
            if(generateMazeButtonState != Enabled) return; //(disabled when generating maze in progress)
            showSearchAlgorithmSelection = true;
        }

    }

    public void hideButtonSelection(string selectionOf){

        if(selectionOf == "Maze"){
            showMazeSelection = false; //toggle
        }else if(selectionOf == "SearchAlgorithm"){
            showSearchAlgorithmSelection = false;
        }

    }

    public void updateButtonStatesWhenClicked(ButtonType clickedButtonType)
    {
        switch(clickedButtonType)
        {
            case ButtonType.GenerateMaze:
            generateMazeButtonState = Active;
            pathFindingAlgorithmsButtonState = Disabled;
            runSearchAlgorithmButtonState = Disabled;
            paintWallButtonState = Disabled;
            addEndnodeButtonState = Disabled;
            cleartWallButtonState = Disabled;
            EndnodeAndWallEraserButtonState = Disabled;
            break;

            case ButtonType.RunSearchAlgorithm:
            runSearchAlgorithmButtonState = Active;
            pauseButtonState = Enabled;
            resetButtonState = Enabled;
            paintWallButtonState = Enabled;
            EndnodeAndWallEraserButtonState = Enabled;
            generateMazeButtonState = Disabled;
            cleartWallButtonState = Disabled;
            addEndnodeButtonState = Disabled;
            break;

            case ButtonType.PauseSearch:
            pauseButtonState = Active;
            resetButtonState = Enabled;
            runSearchAlgorithmButtonState = Enabled;
            generateMazeButtonState = Enabled;
            if(endnodeCount < 3 && currentlyActiveSearchAlgorithm != "Bidirectional")  addEndnodeButtonState = Enabled;
            paintWallButtonState = Enabled;
            EndnodeAndWallEraserButtonState = Enabled;
            break;

            case ButtonType.ResetSearch:
            runSearchAlgorithmButtonState = Enabled;
            generateMazeButtonState = Enabled;
            if(endnodeCount < 3 && currentlyActiveSearchAlgorithm != "Bidirectional")  addEndnodeButtonState = Enabled;
            paintWallButtonState = Enabled;
            EndnodeAndWallEraserButtonState = Enabled;
            resetButtonState = Disabled;
            pauseButtonState = Disabled;
            break;

            case ButtonType.PaintWall:
            paintWallButtonState = ActiveClickable;
            EndnodeAndWallEraserButtonState = Enabled;
            break;

            case ButtonType.ClearWalls:
            //cleartWallButtonState = Disabled;
            break;

            case ButtonType.EndnodeAndWallEraser:
            EndnodeAndWallEraserButtonState = ActiveClickable;
            paintWallButtonState = Enabled;
            break;
        }
    }

    public void updateButtonStatesWhenTaskDone(ButtonType taskFromButtonCompleted)
    {
        switch(taskFromButtonCompleted){

            case ButtonType.GenerateMaze:
            pathFindingAlgorithmsButtonState = Enabled;
            runSearchAlgorithmButtonState = Enabled;
            paintWallButtonState = Enabled;
            generateMazeButtonState = Enabled;
            cleartWallButtonState = Enabled;
            if(endnodeCount < 3 && currentlyActiveSearchAlgorithm != "Bidirectional")  addEndnodeButtonState = Enabled;
            EndnodeAndWallEraserButtonState = Enabled;
            break;

            case ButtonType.RunSearchAlgorithm: //used in algorithmCompletesWithoutUserInterupting method
            generateMazeButtonState = Enabled;
            runSearchAlgorithmButtonState = Enabled;
            resetButtonState = Enabled;
            cleartWallButtonState = Enabled;
            if(pauseButtonState != Active) pauseButtonState = Disabled; //ignore if user dragged special node to endnode and showed best path WHILE PAUSED
            if(endnodeCount < 3 && currentlyActiveSearchAlgorithm != "Bidirectional")  addEndnodeButtonState = Enabled;
            break;

            case ButtonType.PaintWall: //tiggered when pressing paintwall button while active
            paintWallButtonState = Enabled;
            //cleartWallButtonState = Disabled;
            break;

            case ButtonType.EndnodeAndWallEraser: //tiggered when pressing EndnodeAndWallEraser button while active
            EndnodeAndWallEraserButtonState = Enabled;
            break;
        }
    }

    public Node? getNodeWithCoordinates(int xPos, int yPos)
    {
        int row =  (xPos - (nodeSize / 2)) / nodeSize;
        int col = (yPos - alotedSpaceForHeader) / nodeSize;
        
        if(row >= 0 && col >= 0 && row < grid?.GetLength(0) && col < grid.GetLength(1)) return grid![row, col];//check for out of bounds
        else return null;
        
    }


    public async Task togglePaintWall(){
        if(paintWallButtonState == Enabled) {
            await pauseSearchAlgorithm(); //Pause Search to avoid goofy interactions
            updateButtonStatesWhenClicked(ButtonType.PaintWall);
            transitionDelay = 0.5; //show consistent transition when making walls
        }
        else if(paintWallButtonState == ActiveClickable) updateButtonStatesWhenTaskDone(ButtonType.PaintWall);
    } 
    public async Task toggleEndnodeAndWallEraser(){

        if(EndnodeAndWallEraserButtonState == Enabled) {
            await pauseSearchAlgorithm(); //Pause Search to avoid goofy interactions
            updateButtonStatesWhenClicked(ButtonType.EndnodeAndWallEraser);
            transitionDelay = 0.5; //show consistent transition when making walls
        }
        else if(EndnodeAndWallEraserButtonState == ActiveClickable) updateButtonStatesWhenTaskDone(ButtonType.EndnodeAndWallEraser);
    } 

    public async Task removeWalls()
    {
        transitionDelay = 0;
        await runMazeGenerationAlgorithms("clearWalls");
        updateButtonStatesWhenClicked(ButtonType.ClearWalls);
        StateHasChanged();
        if(pathfindingAlgorithmSpeed != 3) transitionDelay = 0.5;
    }

    public void addEndnode(int rowIndex = 0, int colIndex = 0)
    {
        Node? nodeFromCoordinates;
        bool endnodeAdded = false;

        if(rowIndex + colIndex == 0)//if no corrdinates given add to default point (middle)
        {

            for(int colToAddEndnode = 10; !endnodeAdded && colToAddEndnode < 25; colToAddEndnode++) //continue until there is a new endnode added or past row limit
            {  
                if(colToAddEndnode < 0 && colToAddEndnode >= grid?.GetLength(1)) continue;//check for out of bounds

                nodeFromCoordinates = grid?[41, colToAddEndnode];

                if(nodeFromCoordinates?.EndPoint == false)
                {
                    nodeFromCoordinates.setAsNewEndPoint();
                    endnodeAdded = true;
                    endnodeCount++;
                }

                if(endnodeCount >= 3)
                {
                    addEndnodeButtonState = Disabled;
                    return;
                }
            }

        }else 
        {
            if(rowIndex < 0 && colIndex >= grid?.GetLength(0)) return;//check for out of bounds

            nodeFromCoordinates = grid?[rowIndex, colIndex];
            nodeFromCoordinates?.setAsNewEndPoint();
            endnodeCount++;
        }
        

    }
    
    private void changePageForModal(bool nextPage){
        
        if(nextPage)//page to the next
        {
            if(manualCurrentPageNumber < 4)manualCurrentPageNumber++;
        }
        else//page to the back
        {
            if(manualCurrentPageNumber > 0)manualCurrentPageNumber--;
        }
            

    }

    private void toggleModal()
    {
        manualEnabled = !manualEnabled;
    }

    private void changePathfindingSpeed()
    {
        pathfindingAlgorithmSpeed++;

        if(pathfindingAlgorithmSpeed > 3) pathfindingAlgorithmSpeed = 0;

        switch(pathfindingAlgorithmSpeed)
        {
            case 0:
            pathfindingAlgorithm!.modifyPathfindingDelay(230);
            pathfindingSpeedMode = "Slow";
            break;

            case 1:
            pathfindingAlgorithm!.modifyPathfindingDelay(150);
            pathfindingSpeedMode = "Normal";
            break;

            case 2:
            pathfindingAlgorithm!.modifyPathfindingDelay(100);
            pathfindingSpeedMode = "Fast";
            break;

            case 3:
            pathfindingAlgorithm!.modifyPathfindingDelay(0);
            pathfindingSpeedMode = "Instant";
            break;
        }

    }
